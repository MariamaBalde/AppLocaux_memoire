REACT_APP_API_URL=http://localhost:8000/api
# Production (exemple): REACT_APP_API_URL=https://votre-backend.exemple.com/api

# Cloudinary (upload images vendeurs/produits)
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=

# FX rates (1 EUR/USD en XOF)
REACT_APP_FX_EUR=655.957
REACT_APP_FX_USD=590

# Activer seulement si l'API expose /auth/forgot-password et /auth/reset-password
REACT_APP_ENABLE_PASSWORD_RESET_API=true
