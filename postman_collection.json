        {
          "name": "Create - Créer une commande (📧 DÉCLENCHE NOTIFICATIONS)",
          "description": "Crée une commande et déclenche l'envoi de:\n- Email de confirmation au CLIENT\n- Email de notification aux VENDEURS\n- Email de notification à tous les ADMINS (vérification vendeur si nouveau)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ajouter un produit au panier avant de créer la commande"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('order_id', pm.response.json().data.order.id);",
                  "    console.log('✅ Commande créée: ' + pm.response.json().data.order.id);",
                  "    console.log('📧 Notifications envoyées!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{client_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": \"123 Rue de Dakar, Senegal\",\n  \"phone\": \"+221771234567\",\n  \"shipping_method\": \"standard\",\n  \"payment_method\": \"wave\",\n  \"notes\": \"Livrer en fin d'après-midi\"\n}",
              "options": {
